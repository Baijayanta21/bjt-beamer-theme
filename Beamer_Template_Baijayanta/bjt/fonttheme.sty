% for beamer fonts

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{fonttheme}

% Font theme
\usefonttheme{serif}

% Text and math fonts
\RequirePackage{mathptmx}
\RequirePackage{eulervm}
\RequirePackage{bookman}

% Frame title
% change appearance of frametitle 
\setbeamerfont{frametitle}{
    family = \rmfamily,   % serif
    series = \mdseries,   % medium-bold
    shape  = \scshape,    % small caps
    size   = \Large       % size
}

% title and authorname font customization (currently diabled)
