% for beamer theme extra commands


\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{commands}


% frame related shortcut

% make a frame
\NewDocumentCommand{\myframe}{ O{} m m }{%
    \begin{frame}[#1]{#2}
        #3
    \end{frame}
}

% Usage:
% \myframe[<frame-options>]{<frame-title>}{<frame-content>}
% <frame-options> is optional (default: empty)
% Examples:
% \myframe{Introduction}{This is the first slide.}
% \myframe[t]{Introduction}{Top-aligned slide.}
%
% \myframe[fragile]{Code}{
%   \begin{verbatim}
%   print("Hello")
%   \end{verbatim}}
%
% \myframe[t,fragile]{Example}{Frame with multiple options.}

% Empty slide
\newcommand{\blankframe}{%
    \begin{frame}[plain]
    \end{frame}
}

% Usage:
% \blankframe
%
% Inserts a blank Beamer frame with the `plain` option
% (no headline, footline, or navigation elements).


