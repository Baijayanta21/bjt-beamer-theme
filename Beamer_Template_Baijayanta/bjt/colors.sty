% for beamer colors

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{colors}

% Color theme
\usecolortheme{beaver}
\usecolortheme{rose}

% change the color of progress bar
\setbeamercolor{progress bar}{fg=red!70,bg=gray}

% set the colors of normal text, title, frametitle, section title and more
\setbeamercolor{normal text}{fg=black,bg=white}   % Set normal text and background colors
\setbeamercolor{structure}{fg=blue!80}            % Color for structural elements (bullets, sections, etc.)
\setbeamercolor{title}{fg=black}                  % Set presentation title color to blue 
%\setbeamercolor{frametitle}{fg=black, bg=blue!4} % Set frame title color to black       (currently disabled)
\setbeamercolor{section title}{fg=black}          % Set section page title color


% set title and body colors of different blocks (diabled)

% % Normal block
% \setbeamercolor{block title}{fg=black,bg=red!15}
% \setbeamercolor{block body}{fg=black,bg=blue!10}

% % Alert block
% \setbeamercolor{block title alerted}{fg=black!80!red,bg=red!40}
% \setbeamercolor{block body alerted}{fg=black,bg=red!10!white}

% % Example block
\setbeamercolor{block title example}{fg=green!25!black,bg=green!20}
\setbeamercolor{block body example}{fg=black,bg=green!10}


