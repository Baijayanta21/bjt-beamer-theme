% for beamer references

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{references}

% bibilography References
\NewDocumentCommand{\referencesframe}{O{unsrt} m}{%
    \begin{frame}[allowframebreaks]{References}
        \bibliographystyle{#1}
        \bibliography{#2}
    \end{frame}
}

% Usage:
% \referencesframe[<bib-style>]{<bib-file-name>}
% \referencesframe % by default unsrt style and references.bib
% bib style is not mandatory if file name provided
% \referencesframe{bjt-ref.bib}             % insert only bib file name
% \referencesframe[abbrvnat]{bjt-ref.bib}   % insert bib file name and bib style

\endinput