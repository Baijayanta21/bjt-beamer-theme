% for beamer titlepage

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{titlepage}

% Title Page
%--------------------------------------------------------------------

\newcommand{\titlebackground}[2][0.10]{%
    \def\titlebackgroundopacity{#1}%
    \def\inserttitlebackground{#2}%
}

% Usage:
% \titlebackground[<opacity>]{<image-file-name>}
% opacity is optional, by default set to 0.1
% \titlebackground{wallpaper.jpg}           % only file name
% \titlebackground[0.25]{wallpaper.jpg}     % file name and opacity

% by default no background 
\def\inserttitlebackground{}
\def\titlebackgroundopacity{0.10}


\setbeamertemplate{title page}{
\begin{tikzpicture}[remember picture,overlay]

% Background and opacity settings
\ifx\inserttitlebackground\@empty
    % No background image draw something else
    
    % Accent bar
    \fill[blue!40] (current page.north west) rectangle ([xshift=0.2cm]current page.south west);
    
    \fill[blue!10](current page.north east) circle (2cm);
    \fill[blue!10](current page.south east) circle (2cm);
    
    \fill[black, opacity=0.05] (current page.north west) rectangle (current page.south east);
    
\else
    \node[opacity=\titlebackgroundopacity] at (current page.center) {\includegraphics[width=\paperwidth,height=\paperheight]{\inserttitlebackground}};
    \fill[black, opacity=0.05] (current page.north west) rectangle (current page.south east);
\fi
\end{tikzpicture}

\vspace*{0.5cm}
{\usebeamerfont{title}\color{black}\inserttitle\par}

\vspace{0.25cm}
{\usebeamerfont{subtitle}\color{gray!20!black}\insertsubtitle\par}

\vspace{1cm}
{\Large\bfseries\insertauthor\par}

\vspace{0.3cm}
{\large\insertinstitute\par}

\vfill
{\insertdate}}

\newcommand{\maketitleframe}{
\begin{frame}[plain]
\titlepage
\end{frame}
}

\endinput