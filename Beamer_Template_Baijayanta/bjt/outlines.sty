% for beamer outlines

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{outlines}

% Outline page
\newcommand{\outlineframe}[1][Outline]{
\begin{frame}{#1}
    \tableofcontents
\end{frame}
}
% Usage:
% \outlineframe[<frame-title>]
% \outlineframe[Today's Topics] 
% by default the frame title is Outline

\endinput