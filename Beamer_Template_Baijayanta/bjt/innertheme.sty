% for beamer innertheme

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{innertheme}

% Base inner theme
\useinnertheme{rectangles}

% Blocks
\setbeamertemplate{blocks}[rounded][shadow=true] % Rounded blocks with shadow

% Captions
\setbeamertemplate{caption}[numbered]            % Number figure/table captions

% Lists
\setbeamertemplate{itemize item}{\ensuremath{\checkmark}}
\setbeamertemplate{itemize item}{$\blacktriangleright$}

\endinput