% for beamer background

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{backgrounds}

% slide background settings
%--------------------------------------------------------------------

\newcommand{\slidebackground}[2][0.10]{%
    \def\slidebackgroundopacity{#1}%
    \def\insertslidebackground{#2}%
}

% Usage:
% \slidebackground[<opacity>]{<image-file-name>}
% opacity is optional, by default set to 0.1
% \slidebackground{wallpaper.jpg}           % only file name
% \slidebackground[0.25]{wallpaper.jpg}     % file name and opacity

% by default no slide background 
\def\insertslidebackground{}
\def\slidebackgroundopacity{0.10}

\usebackgroundtemplate{%
\begin{tikzpicture}[remember picture,overlay]
\ifx\insertslidebackground\@empty
    % No background image draw something else
\else
    \node[opacity=\slidebackgroundopacity] at (current page.center) {\includegraphics[width=\paperwidth,height=\paperheight]{\insertslidebackground}};
    \fill[black, opacity=0.05] (current page.north west) rectangle (current page.south east);
\fi

\end{tikzpicture}}

\endinput